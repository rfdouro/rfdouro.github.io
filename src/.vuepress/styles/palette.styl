/*consulte em https://github.com/vuejs/vuepress/blob/master/packages/%40vuepress/theme-default/styles/index.styl*/

$accentColor = #AA00AA
$textColor = #0011AA
$borderColor = #006600
$codeBgColor = #333333
$arrowBgColor = #0e656f

$bgColor1 = #70bfdf
$bgColor2 = #bae3e8

html, body
  padding 0
  margin 0
  background-color $bgColor2

.sidebar
  font-size 16px
  background-color $bgColor1

.navbar
  background-color $bgColor1

.navbar .links
  background-color $bgColor1